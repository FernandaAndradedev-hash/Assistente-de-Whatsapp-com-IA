# APIs de IA ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-coloque-sua-chave-aqui
ANTHROPIC_API_KEY=sk-ant-coloque-sua-chave-aqui

# Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=clinic_knowledge

# Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_SESSION_TTL=1800       

# Evolution API ─────────────────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-evolution-aqui   
EVOLUTION_INSTANCE=clinica-vida-mais         

# Webhook ───────────────────────────────────────────────────────────────────
WEBHOOK_URL=http://localhost:8000/webhook    
WEBHOOK_SECRET=sua-chave-secreta-hmac-aqui  

# Modelos ───────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=claude-haiku-4-5

# Segurança ─────────────────────────────────────────────────────────────────
MAX_MESSAGE_LENGTH=500
RATE_LIMIT_MAX_MESSAGES=10
RATE_LIMIT_WINDOW_SECONDS=60